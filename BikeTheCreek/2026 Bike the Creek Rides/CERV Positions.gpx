<?xml version="1.0"?>
<gpx version="1.1" creator="GDAL 3.6.3" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ogr="http://osgeo.org/gdal" xmlns="http://www.topografix.com/GPX/1/1" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
<metadata><bounds minlat="43.695638700000003" minlon="-79.817804699999996" maxlat="43.740800999999998" maxlon="-79.733917800000000"/></metadata>                
<wpt lat="43.740801" lon="-79.8178047">
  <name>CERV 1</name>
  <extensions>
    <ogr:description>Location: Northwest corner of Snellview and Mayfield. Duration: 10:am - 1:15pm. Rides: Family, Orange, Town, Regional. Responsibilities: Keep riders on right side of Snellview. Press light button when there are a group of riders. Prevent riders from continuing on yellow. Peel Regional Police on southwest corner.</ogr:description>
  </extensions>
</wpt>
<wpt lat="43.7356016" lon="-79.8036879">
  <name>CERV 2</name>
  <extensions>
    <ogr:description>Location: Southwest corner Conservation &amp; Kennedy. Duration: 9:00am-10:30am. Rides: Bramalea. Responsibilities: Keep riders on left side of right lane adjacent to the left-turn lane to allow cars to turn right. Press light button when there are a group of riders. Prevent riders from continuing on yellow</ogr:description>
  </extensions>
</wpt>
<wpt lat="43.719464" lon="-79.7339178">
  <name>CERV 3</name>
  <extensions>
    <ogr:description>Location: Northeast corner Howden &amp; Dixie. Duration: 10:00am - 11:30am. Rides: Bramalea: Responsibilities: Keep riders in the bike lane. Watch for right-hand turning cars. Press light button when there are a group of riders. Direct riders into closed traffic lane on Howden west of Dixie. Prevent riders from continuing on yellow</ogr:description>
  </extensions>
</wpt>
<wpt lat="43.6956387" lon="-79.7974728">
  <name>CERV 4</name>
  <extensions>
    <ogr:description>Location: Southwest corner Bovaird &amp; McLaughlin. Duration: 10:15am - 11:45am. Ride: Bramalea. Responsibilities: Watch for riders coming up the Fletcher’s Creek Trail. Direct riders east to the southwest corner of Bovaird &amp; McLaughlin. Press light button when there are a group of riders. Direct riders to cross to the northwest corner and proceed west to Fletcher’s Creek Trail. Prevent riders from continuing on yellow.</ogr:description>
  </extensions>
</wpt>
</gpx>
